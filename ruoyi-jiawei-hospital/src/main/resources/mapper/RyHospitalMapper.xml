<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.hospital.mapper.RyHospitalMapper">

    <!--
      ============================================
      基础 CRUD (insert/updateById/deleteById/selectById/selectList等)
      由 BaseMapperProvider 自动生成SQL，无需在此定义！
      ============================================
    -->

    <resultMap id="BaseResultMap" type="com.ruoyi.hospital.domain.po.RyHospital">
        <id column="id" property="id"/>
        <result column="hospital_name" property="hospitalName"/>
        <result column="hospital_grade" property="hospitalGrade"/>
        <result column="hospital_label" property="hospitalLabel"/>
        <result column="hospital_cover" property="hospitalCover"/>
        <result column="hospital_address" property="hospitalAddress"/>
        <result column="brief_introduction" property="briefIntroduction"/>
        <result column="enclosures" property="enclosures"/>
        <result column="hospital" property="hospital"/>
        <result column="hospital_position" property="hospitalPosition"/>
        <result column="is_deleted" property="isDeleted"/>
        <result column="version" property="version"/>
        <result column="memo" property="memo"/>
        <result column="create_user_id" property="createUserId"/>
        <result column="create_user_name" property="createUserName"/>
        <result column="update_user_id" property="updateUserId"/>
        <result column="update_user_name" property="updateUserName"/>
        <result column="gmt_create" property="createTime"/>
        <result column="gmt_modified" property="updateTime"/>
        <result column="sort" property="sort"/>
        <result column="hospital_longitude" property="hospitalLongitude"/>
        <result column="region_id" property="regionId"/>
    </resultMap>

    <!-- ========== 自定义查询（只写复杂的，基础CRUD由BaseMapperProvider自动生成） ========== -->

    <select id="selectHospitalList" parameterType="com.ruoyi.hospital.domain.query.RyHospitalQuery" resultMap="BaseResultMap">
        SELECT * FROM ry_hospital WHERE is_deleted = 0
        <if test="hospitalName != null and hospitalName != ''">
            AND hospital_name LIKE CONCAT('%', #{hospitalName}, '%')
        </if>
        <if test="hospitalGrade != null and hospitalGrade != ''">
            AND hospital_grade = #{hospitalGrade}
        </if>
        <if test="regionId != null and regionId != ''">
            AND region_id = #{regionId}
        </if>
        ORDER BY sort ASC, gmt_create DESC
    </select>

</mapper>
